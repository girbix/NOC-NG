@model IEnumerable<Incident>
@{
    ViewData["Title"] = "Tech Dashboard";
}
<table class="ticket-table">
    <thead><tr><th>Numero</th><th>Descrizione</th><th>Stato</th><th>Team</th></tr></thead>
    <tbody>
        @foreach (var t in Model)
        {
            <tr onclick="location.href='/Tech/IncidentDetail/@t.Id'">
                <td>@t.Number</td><td>@t.ShortDescription</td><td>@t.State</td><td>@t.AssignedTeam</td>
            </tr>
        }
    </tbody>
</table>
