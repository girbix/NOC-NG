<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - NOC NG</title>
    <link rel="stylesheet" href="~/css/site.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
</head>
<body class="dark-mode">
    <div class="header">
        <h1><i class="fas fa-network-wired"></i> NOC Next Generation</h1>
        <div class="red-line"></div>
        <div class="user-info">
            <span>@User.FindFirst("FullName")?.Value</span> | <a href="/Account/Logout">Logout</a>
        </div>
        <button id="themeToggle" class="theme-btn"><i class="fas fa-moon"></i></button>
    </div>
    <div class="container">
        @RenderBody()
    </div>
    <script src="~/js/site.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
